{
    "editor.codeActionsOnSave": {
        "source.fixAll.markdownlint": "explicit"
    },
    "markdownlint.run": "onSave",
    "files.exclude": {
        "**/.git": false,
        "**/.svn": false,
        "**/.hg": false,
        "**/.DS_Store": false,
        "**/Thumbs.db": false,
        "**/CVS": false,
        "**/.ruby-lsp": false,
        "**/pesde/**": false,
        "**/luau_packages/**": false,
        "**/lune_packages/**": false,
        "**/roblox_packages/**": false,
        "**/node_modules/**": false,
        "**/dist/**": false,
        "**/tmp/**": false,
        "**/out/**": false,
        "/libs/**": false
    },
    "explorerExclude.backup": {}
}